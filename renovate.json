{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 1,
  "rangeStrategy": "pin",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.java$"],
      "matchStrings": ["renovate:\\s*datasource=docker\\s+depName=(?<depName>\\S+)\\n\\s*.+\"\\k<depName>:(?<currentValue>[\\w.-]+)\""],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchDepNames": ["postgres"],
      "groupName": "postgres"
    }
  ]
}
